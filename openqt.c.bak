char *stristr(const char *haystack, const char *needle)
{
    size_t needle_len, i;
    if (!haystack || !needle) return NULL;
    needle_len = strlen(needle);
    for (i = 0; i <= strlen(haystack) - needle_len; i++) {
        if (strnicmp(haystack + i, needle, needle_len) == 0)
            return (char *)(haystack + i);
    }
    return NULL;
}

void write_char(int x, int y, unsigned char ch, unsigned char attr)
{
    if (x >= 0 && x < SCREEN_WIDTH && y >= 0 && y < SCREEN_HEIGHT) {
        video_mem[(y * SCREEN_WIDTH + x) * 2] = ch;
        video_mem[(y * SCREEN_WIDTH + x) * 2 + 1] = attr;
    }
}

void write_string(int x, int y, const char *str, unsigned char attr)
{
    while (*str && x < SCREEN_WIDTH) {
        write_char(x++, y, (unsigned char)*str++, attr);
    }
}

void fill_rect(int x1, int y1, int x2, int y2, unsigned char ch, unsigned char attr)
{
    int x, y;
    for (y = y1; y <= y2; y++)
        for (x = x1; x <= x2; x++)
            write_char(x, y, ch, attr);
}

void draw_box(int x1, int y1, int x2, int y2, unsigned char attr, const char *title)
{
    int i, len, tx;
    write_char(x1, y1, 0xDA, attr);
    for (i = x1 + 1; i < x2; i++) write_char(i, y1, 0xC4, attr);
    write_char(x2, y1, 0xBF, attr);
    for (i = y1 + 1; i < y2; i++) {
        write_char(x1, i, 0xB3, attr);
        write_char(x2, i, 0xB3, attr);
    }
    write_char(x1, y2, 0xC0, attr);
    for (i = x1 + 1; i < x2; i++) write_char(i, y2, 0xC4, attr);
    write_char(x2, y2, 0xD9, attr);
    fill_rect(x1 + 1, y1 + 1, x2 - 1, y2 - 1, ' ', attr);
    if (title && *title) {
        len = strlen(title);
        tx = x1 + (x2 - x1 - len - 2) / 2;
        write_char(tx, y1, ' ', attr);
        write_string(tx + 1, y1, title, attr);
        write_char(tx + len + 1, y1, ' ', attr);
    }
}

void set_cursor_pos(int x, int y)
{
    union REGS regs;
    regs.h.ah = 0x02;
    regs.h.bh = 0;
    regs.h.dh = (unsigned char)y;
    regs.h.dl = (unsigned char)x;
    int386(0x10, &regs, &regs);
}

void hide_cursor(void)
{
    union REGS regs;
    regs.h.ah = 0x01;
    regs.h.ch = 0x20;
    regs.h.cl = 0x00;
    int386(0x10, &regs, &regs);
}

void show_cursor(int ins_mode)
{
    union REGS regs;
    regs.h.ah = 0x01;
    regs.h.ch = (unsigned char)(ins_mode ? 6 : 0);
    regs.h.cl = 7;
    int386(0x10, &regs, &regs);
}

void init_hebrew_mapping(void)
{
    memset(heb_final, 0, sizeof(heb_final));
    /* Map regular letters to their final (sofit) forms */
    heb_final[139] = 138;  /* כ (Kaf) -> ך (Kaf Sofit) */
    heb_final[142] = 141;  /* מ (Mem) -> ם (Mem Sofit) */
    heb_final[144] = 143;  /* נ (Nun) -> ן (Nun Sofit) */
    heb_final[148] = 147;  /* פ (Pe) -> ף (Pe Sofit) */
    heb_final[150] = 149;  /* צ (Tsadi) -> ץ (Tsadi Sofit) */
}

unsigned char translate_hebrew(unsigned char ch)
{
    if (ch < 128) return heb_map[ch];
    return ch;
}

int is_hebrew_char(unsigned char ch)
{
    return (ch >= HEB_FIRST && ch <= HEB_LAST);
}


/* Get BiDi character type */
int get_bidi_type(unsigned char ch)
{
    if (ch >= HEB_FIRST && ch <= HEB_LAST) return BIDI_R;
    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) return BIDI_L;
    if (ch >= '0' && ch <= '9') return BIDI_EN;
    if (ch == ' ' || ch == '\t') return BIDI_WS;
    return BIDI_ON;
}

/* Perform BiDi reordering on a line */
void bidi_reorder(const char *logical, int len)
{
    int i, j, k;
    int run_start, run_end;
    int max_level, level;
    int temp_log[MAX_LINE_LEN];
    unsigned char temp_vis[MAX_LINE_LEN];
    int base_level;
    
    if (len <= 0 || len >= MAX_LINE_LEN) { bidi.len = 0; return; }
    
    bidi.len = len;
    base_level = doc.rtl_mode ? 1 : 0;
    
    /* Step 1: Assign character types */
    for (i = 0; i < len; i++) {
        bidi.types[i] = get_bidi_type((unsigned char)logical[i]);
        bidi.levels[i] = base_level;
    }
    
    /* Step 2: Assign embedding levels */
    for (i = 0; i < len; i++) {
        if (bidi.types[i] == BIDI_R) {
            bidi.levels[i] = 1;  /* Hebrew always RTL */
        }
        else if (bidi.types[i] == BIDI_L || bidi.types[i] == BIDI_EN) {
            /* English and numbers: embedded LTR in RTL context */
            bidi.levels[i] = doc.rtl_mode ? 2 : 0;
        }
        else {
            /* Neutrals: resolve by surrounding context */
            int prev_strong = base_level ? BIDI_R : BIDI_L;
            int next_strong = base_level ? BIDI_R : BIDI_L;
            
            for (j = i - 1; j >= 0; j--) {
                if (bidi.types[j] == BIDI_R) { prev_strong = BIDI_R; break; }
                if (bidi.types[j] == BIDI_L || bidi.types[j] == BIDI_EN) { prev_strong = BIDI_L; break; }
            }
            for (j = i + 1; j < len; j++) {
                if (bidi.types[j] == BIDI_R) { next_strong = BIDI_R; break; }
                if (bidi.types[j] == BIDI_L || bidi.types[j] == BIDI_EN) { next_strong = BIDI_L; break; }
            }
            
            if (prev_strong == next_strong) {
                bidi.levels[i] = (prev_strong == BIDI_R) ? 1 : (doc.rtl_mode ? 2 : 0);
            } else {
                bidi.levels[i] = base_level;
            }
        }
    }
    
    /* Step 3: Initialize for reordering */
    for (i = 0; i < len; i++) {
        temp_log[i] = i;
        temp_vis[i] = (unsigned char)logical[i];
    }
    
    /* Step 4: Reorder if RTL base */
    if (doc.rtl_mode) {
        max_level = 0;
        for (i = 0; i < len; i++) {
            if (bidi.levels[i] > max_level) max_level = bidi.levels[i];
        }
        
        /* Reverse runs at each level from max down to 1 */
        for (level = max_level; level >= 1; level--) {
            i = 0;
            while (i < len) {
                if (bidi.levels[i] >= level) {
                    run_start = i;
                    while (i < len && bidi.levels[i] >= level) i++;
                    run_end = i - 1;
                    
                    /* Reverse this run */
                    for (j = run_start, k = run_end; j < k; j++, k--) {
                        unsigned char tc = temp_vis[j];
                        int tl = temp_log[j];
                        temp_vis[j] = temp_vis[k];
                        temp_log[j] = temp_log[k];
                        temp_vis[k] = tc;
                        temp_log[k] = tl;
                    }
                } else {
                    i++;
                }
            }
        }
        
        /* Reverse entire line for RTL base */
        for (j = 0, k = len - 1; j < k; j++, k--) {
            unsigned char tc = temp_vis[j];
            int tl = temp_log[j];
            temp_vis[j] = temp_vis[k];
            temp_log[j] = temp_log[k];
            temp_vis[k] = tc;
            temp_log[k] = tl;
        }
    }
    
    /* Step 5: Store results */
    for (i = 0; i < len; i++) {
        bidi.visual[i] = temp_vis[i];
        bidi.vis_to_log[i] = temp_log[i];
    }
    
    /* Build reverse mapping */
    for (i = 0; i < len; i++) {
        bidi.log_to_vis[bidi.vis_to_log[i]] = i;
    }
}

int visual_to_logical(int vis_pos)
{
    if (vis_pos < 0) return 0;
    if (vis_pos >= bidi.len) return bidi.len;
    return bidi.vis_to_log[vis_pos];
}

int logical_to_visual(int log_pos)
{
    if (log_pos < 0) return 0;
    if (log_pos >= bidi.len) return bidi.len;
    return bidi.log_to_vis[log_pos];
}


void apply_final_letters(char *line)
{
    int i, len;
    unsigned char ch, next;
    if (!line) return;
    len = strlen(line);
    for (i = 0; i < len; i++) {
        ch = (unsigned char)line[i];
        next = (i < len - 1) ? (unsigned char)line[i + 1] : ' ';
        if (heb_final[ch] && (next == ' ' || next == '\0' || !is_hebrew_char(next)))
            line[i] = heb_final[ch];
    }
}

void init_document(void)
{
    doc.lines = (char **)malloc(MAX_LINES * sizeof(char *));
    if (!doc.lines) { printf("Memory allocation failed!\n"); exit(1); }
    memset(doc.lines, 0, MAX_LINES * sizeof(char *));
    
    doc.lines[0] = (char *)malloc(MAX_LINE_LEN);
    if (!doc.lines[0]) { printf("Memory allocation failed!\n"); exit(1); }
    doc.lines[0][0] = '\0';
    doc.num_lines = 1;
    doc.max_lines = MAX_LINES;
    doc.modified = 0;
    strcpy(doc.filename, "NONAME.TXT");
    doc.cursor_x = 0;
    doc.cursor_y = 0;
    doc.scroll_x = 0;
    doc.scroll_y = 0;
    doc.insert_mode = 1;
    doc.hebrew_mode = 1;
    doc.rtl_mode = 1;  /* RTL mode for Hebrew */
    doc.word_wrap = 1;
    doc.show_ruler = 1;
    doc.block_active = 0;
    doc.clipboard = NULL;
    doc.clipboard_lines = 0;
}

void free_document(void)
{
    int i;
    if (doc.lines) {
        for (i = 0; i < doc.num_lines; i++)
            if (doc.lines[i]) free(doc.lines[i]);
        free(doc.lines);
        doc.lines = NULL;
    }
    if (doc.clipboard) {
        for (i = 0; i < doc.clipboard_lines; i++)
            if (doc.clipboard[i]) free(doc.clipboard[i]);
        free(doc.clipboard);
        doc.clipboard = NULL;
    }
}

void new_document(void)
{
    int i;
    if (doc.modified) {
        if (!confirm_dialog("New Document", "Discard changes?")) return;
    }
    for (i = 0; i < doc.num_lines; i++) {
        if (doc.lines[i]) { free(doc.lines[i]); doc.lines[i] = NULL; }
    }
    doc.lines[0] = (char *)malloc(MAX_LINE_LEN);
    doc.lines[0][0] = '\0';
    doc.num_lines = 1;
    doc.modified = 0;
    doc.cursor_x = 0;
    doc.cursor_y = 0;
    doc.scroll_x = 0;
    doc.scroll_y = 0;
    doc.block_active = 0;
    hebrew_insert_pos = 0;
    strcpy(doc.filename, "NONAME.TXT");
    draw_screen();
}

int load_file(const char *filename)
{
    FILE *fp;
    char buffer[MAX_LINE_LEN];
    int line_count = 0;
    int i, len;
    
    fp = fopen(filename, "r");
    if (!fp) { show_dialog("Error", "Cannot open file!"); return 0; }
    
    for (i = 0; i < doc.num_lines; i++) {
        if (doc.lines[i]) { free(doc.lines[i]); doc.lines[i] = NULL; }
    }
    
    while (fgets(buffer, MAX_LINE_LEN, fp) && line_count < MAX_LINES) {
        len = strlen(buffer);
        while (len > 0 && (buffer[len-1] == '\n' || buffer[len-1] == '\r'))
            buffer[--len] = '\0';
        doc.lines[line_count] = (char *)malloc(MAX_LINE_LEN);
        if (!doc.lines[line_count]) { fclose(fp); return 0; }
        strcpy(doc.lines[line_count], buffer);
        line_count++;
    }
    fclose(fp);
    
    if (line_count == 0) {
        doc.lines[0] = (char *)malloc(MAX_LINE_LEN);
        doc.lines[0][0] = '\0';
        line_count = 1;
    }
    doc.num_lines = line_count;
    doc.modified = 0;
    doc.cursor_y = 0;
    doc.scroll_x = 0;
    doc.scroll_y = 0;
    doc.block_active = 0;
    hebrew_insert_pos = 0;
    
    /* In RTL mode, cursor_x should be set to line length so editing works */
    if (doc.rtl_mode) {
        doc.cursor_x = strlen(doc.lines[0]);
    } else {
        doc.cursor_x = 0;
    }
    
    strncpy(doc.filename, filename, sizeof(doc.filename) - 1);
    return 1;
}

int save_file(const char *filename)
{
    FILE *fp;
    int i;
    
    fp = fopen(filename, "w");
    if (!fp) { show_dialog("Error", "Cannot create file!"); return 0; }
    
    for (i = 0; i < doc.num_lines; i++) {
        if (doc.lines[i]) {
            if (doc.hebrew_mode) apply_final_letters(doc.lines[i]);
            fputs(doc.lines[i], fp);
        }
        fputs("\r\n", fp);
    }
    fclose(fp);
    doc.modified = 0;
    strncpy(doc.filename, filename, sizeof(doc.filename) - 1);
    return 1;
}

int save_file_as(void)
{
    char filename[256];
    strcpy(filename, doc.filename);
    if (file_dialog("Save As", filename, sizeof(filename), 1)) {
        return save_file(filename);
    }
    return 0;
}

void draw_menu_bar(void)
{
    int x = 1;
    fill_rect(0, 0, SCREEN_WIDTH - 1, 0, ' ', CLR_MENU);
    write_char(x, 0, 'F', CLR_MENU_HOT); write_string(x + 1, 0, "ile", CLR_MENU); x += 6;
    write_char(x, 0, 'E', CLR_MENU_HOT); write_string(x + 1, 0, "dit", CLR_MENU); x += 6;
    write_char(x, 0, 'S', CLR_MENU_HOT); write_string(x + 1, 0, "earch", CLR_MENU); x += 8;
    write_char(x, 0, 'B', CLR_MENU_HOT); write_string(x + 1, 0, "lock", CLR_MENU); x += 7;
    write_char(x, 0, 'O', CLR_MENU_HOT); write_string(x + 1, 0, "ptions", CLR_MENU); x += 9;
    write_char(x, 0, 'T', CLR_MENU_HOT); write_string(x + 1, 0, "ools", CLR_MENU); x += 7;
    write_char(x, 0, 'H', CLR_MENU_HOT); write_string(x + 1, 0, "elp", CLR_MENU);
    write_string(SCREEN_WIDTH - 10, 0, doc.hebrew_mode ? "[Hebrew]" : "[English]", CLR_MENU);
}

void draw_ruler(void)
{
    int i, cursor_screen_x, len;
    char num[8];
    fill_rect(0, 1, SCREEN_WIDTH - 1, 1, 0xC4, CLR_TITLE);
    
    if (doc.rtl_mode) {
        /* RTL ruler: numbers from right to left */
        for (i = 10; i < SCREEN_WIDTH; i += 10) {
            sprintf(num, "%d", i);
            write_string(SCREEN_WIDTH - i, 1, num, CLR_TITLE);
        }
        /* Cursor marker */
        len = doc.lines[doc.cursor_y] ? (int)strlen(doc.lines[doc.cursor_y]) : 0;
        cursor_screen_x = SCREEN_WIDTH - doc.cursor_x;
        if (cursor_screen_x >= 0 && cursor_screen_x < SCREEN_WIDTH)
            write_char(cursor_screen_x, 1, 0x19, CLR_MENU);
    } else {
        /* LTR ruler */
        for (i = 10; i < SCREEN_WIDTH; i += 10) {
            sprintf(num, "%d", i);
            write_string(i - (int)strlen(num) + 1, 1, num, CLR_TITLE);
        }
        if (doc.cursor_x - doc.scroll_x >= 0 && doc.cursor_x - doc.scroll_x < SCREEN_WIDTH)
            write_char(doc.cursor_x - doc.scroll_x, 1, 0x19, CLR_MENU);
    }
}

void draw_line(int screen_row, int doc_line)
{
    int x, len, i, in_block, text_start;
    int by1, by2, bx1, bx2;
    unsigned char ch, attr;
    char *line;
    
    if (doc_line < 0 || doc_line >= doc.num_lines) {
        fill_rect(0, screen_row, SCREEN_WIDTH - 1, screen_row, ' ', CLR_NORMAL);
        return;
    }
    line = doc.lines[doc_line];
    if (!line) {
        fill_rect(0, screen_row, SCREEN_WIDTH - 1, screen_row, ' ', CLR_NORMAL);
        return;
    }
    len = strlen(line);
    
    if (doc.rtl_mode) {
        /* RTL mode: right-align text */
        text_start = SCREEN_WIDTH - len;
        if (text_start < 0) text_start = 0;
        
        for (x = 0; x < SCREEN_WIDTH; x++) {
            i = x - text_start;  /* index into line */
            
            in_block = 0;
            if (doc.block_active && i >= 0 && i < len) {
                by1 = doc.block_start_y < doc.block_end_y ? doc.block_start_y : doc.block_end_y;
                by2 = doc.block_start_y > doc.block_end_y ? doc.block_start_y : doc.block_end_y;
                if (doc_line >= by1 && doc_line <= by2) {
                    if (doc.block_start_y == doc.block_end_y) {
                        bx1 = doc.block_start_x < doc.block_end_x ? doc.block_start_x : doc.block_end_x;
                        bx2 = doc.block_start_x > doc.block_end_x ? doc.block_start_x : doc.block_end_x;
                        in_block = (i >= bx1 && i < bx2);
                    } else if (doc_line == by1) {
                        bx1 = (doc.block_start_y < doc.block_end_y) ? doc.block_start_x : doc.block_end_x;
                        in_block = (i >= bx1);
                    } else if (doc_line == by2) {
                        bx2 = (doc.block_start_y > doc.block_end_y) ? doc.block_start_x : doc.block_end_x;
                        in_block = (i < bx2);
                    } else {
                        in_block = 1;
                    }
                }
            }
            attr = in_block ? CLR_BLOCK : CLR_NORMAL;
            
            if (i >= 0 && i < len) {
                ch = (unsigned char)line[i];
            } else {
                ch = ' ';
            }
            write_char(x, screen_row, ch, attr);
        }
    } else {
        /* LTR mode: left-align */
        for (x = 0; x < SCREEN_WIDTH; x++) {
            i = x + doc.scroll_x;
            
            in_block = 0;
            if (doc.block_active && i >= 0 && i < len) {
                by1 = doc.block_start_y < doc.block_end_y ? doc.block_start_y : doc.block_end_y;
                by2 = doc.block_start_y > doc.block_end_y ? doc.block_start_y : doc.block_end_y;
                if (doc_line >= by1 && doc_line <= by2) {
                    if (doc.block_start_y == doc.block_end_y) {
                        bx1 = doc.block_start_x < doc.block_end_x ? doc.block_start_x : doc.block_end_x;
                        bx2 = doc.block_start_x > doc.block_end_x ? doc.block_start_x : doc.block_end_x;
                        in_block = (i >= bx1 && i < bx2);
                    } else if (doc_line == by1) {
                        bx1 = (doc.block_start_y < doc.block_end_y) ? doc.block_start_x : doc.block_end_x;
                        in_block = (i >= bx1);
                    } else if (doc_line == by2) {
                        bx2 = (doc.block_start_y > doc.block_end_y) ? doc.block_start_x : doc.block_end_x;
                        in_block = (i < bx2);
                    } else {
                        in_block = 1;
                    }
                }
            }
            attr = in_block ? CLR_BLOCK : CLR_NORMAL;
            ch = (i < len) ? (unsigned char)line[i] : ' ';
            write_char(x, screen_row, ch, attr);
        }
    }
}

void draw_status_bar(void)
{
    char status[128], pos[64], timebuf[8];
    time_t now;
    struct tm *t;
    
    fill_rect(0, STATUS_LINE, SCREEN_WIDTH - 1, STATUS_LINE, ' ', CLR_STATUS);
    sprintf(status, " %s%s", doc.filename, doc.modified ? " [Modified]" : "");
    write_string(0, STATUS_LINE, status, CLR_STATUS);
    
    /* Clock */
    now = time(NULL);
    t = localtime(&now);
    sprintf(timebuf, "%02d:%02d", t->tm_hour, t->tm_min);
    write_string(SCREEN_WIDTH - 6, STATUS_LINE, timebuf, CLR_STATUS);
    
    sprintf(pos, "Ln %d/%d Col %d  %s %s %s",
            doc.cursor_y + 1, doc.num_lines, doc.cursor_x + 1,
            doc.insert_mode ? "INS" : "OVR", 
            doc.rtl_mode ? "RTL" : "LTR",
            doc.hebrew_mode ? "HEB" : "ENG");
    write_string(SCREEN_WIDTH - 38, STATUS_LINE, pos, CLR_STATUS);
}

void draw_screen(void)
{
    int i;
    fill_rect(0, 0, SCREEN_WIDTH - 1, SCREEN_HEIGHT - 1, ' ', CLR_NORMAL);
    draw_menu_bar();
    if (doc.show_ruler) draw_ruler();
    for (i = 0; i < EDIT_HEIGHT; i++)
        draw_line(EDIT_TOP + i, doc.scroll_y + i);
    draw_status_bar();
    update_cursor();
}

void update_cursor(void)
{
    int screen_x, screen_y, len, text_start;
    
    screen_y = doc.cursor_y - doc.scroll_y + EDIT_TOP;
    len = doc.lines[doc.cursor_y] ? (int)strlen(doc.lines[doc.cursor_y]) : 0;
    
    if (doc.rtl_mode) {
        /* RTL: text is right-aligned, cursor_x=0 is right edge */
        text_start = SCREEN_WIDTH - len;
        if (text_start < 0) text_start = 0;
        /* Cursor position: right edge minus cursor_x */
        screen_x = SCREEN_WIDTH - doc.cursor_x;
        if (screen_x < 0) screen_x = 0;
        if (screen_x >= SCREEN_WIDTH) screen_x = SCREEN_WIDTH - 1;
    } else {
        /* LTR: normal left-to-right cursor */
        screen_x = doc.cursor_x - doc.scroll_x;
    }
    
    if (!doc.rtl_mode && (screen_x < 0 || screen_x >= SCREEN_WIDTH)) {
        doc.scroll_x = doc.cursor_x - SCREEN_WIDTH / 2;
        if (doc.scroll_x < 0) doc.scroll_x = 0;
        screen_x = doc.cursor_x - doc.scroll_x;
    }
    if (screen_y < EDIT_TOP || screen_y > EDIT_BOTTOM) {
        if (screen_y < EDIT_TOP)
            doc.scroll_y = doc.cursor_y;
        else
            doc.scroll_y = doc.cursor_y - EDIT_HEIGHT + 1;
        if (doc.scroll_y < 0) doc.scroll_y = 0;
        screen_y = doc.cursor_y - doc.scroll_y + EDIT_TOP;
        draw_screen();
    }
    set_cursor_pos(screen_x, screen_y);
    show_cursor(doc.insert_mode);
}

int get_key(void)
{
    int ch = getch();
    if (ch == 0 || ch == 0xE0) return 0x100 | getch();
    return ch;
}

void insert_char(unsigned char ch)
{
    char *line;
    int len;
    int is_hebrew = (ch >= 128);  /* Hebrew chars are 128-154 in CP862 */
    
    if (doc.cursor_y >= doc.num_lines) return;
    line = doc.lines[doc.cursor_y];
    if (!line) return;
    len = strlen(line);
    if (len >= MAX_LINE_LEN - 1) return;
    doc.modified = 1;
    
    if (doc.rtl_mode) {
        /* Ensure hebrew_insert_pos is valid */
        if (hebrew_insert_pos > len) hebrew_insert_pos = len;
        
        if (is_hebrew) {
            /* Hebrew: insert at hebrew_insert_pos (builds RTL within block) */
            memmove(line + hebrew_insert_pos + 1, line + hebrew_insert_pos, len - hebrew_insert_pos + 1);
            line[hebrew_insert_pos] = ch;
            /* hebrew_insert_pos stays same - next Hebrew goes to same position */
        } else {
            /* LTR (numbers, English, punctuation): append at end */
            line[len] = ch;
            line[len + 1] = '\0';
            /* Move hebrew_insert_pos to end so next Hebrew block starts here */
            hebrew_insert_pos = len + 1;
        }
        doc.cursor_x++;
    } else {
        /* LTR mode: normal insertion at cursor */
        if (doc.insert_mode) {
            memmove(line + doc.cursor_x + 1, line + doc.cursor_x, len - doc.cursor_x + 1);
            line[doc.cursor_x] = ch;
        } else {
            if (doc.cursor_x >= len) {
                while (len < doc.cursor_x) line[len++] = ' ';
                line[doc.cursor_x] = ch;
                line[doc.cursor_x + 1] = '\0';
            } else {
                line[doc.cursor_x] = ch;
            }
        }
        doc.cursor_x++;
    }
}

void delete_char(void)
{
    char *line;
    int len;
    if (doc.cursor_y >= doc.num_lines) return;
    line = doc.lines[doc.cursor_y];
    if (!line) return;
    len = strlen(line);
    
    if (doc.cursor_x < len) {
        memmove(line + doc.cursor_x, line + doc.cursor_x + 1, len - doc.cursor_x);
        doc.modified = 1;
    } else if (doc.cursor_y < doc.num_lines - 1) {
        char *next = doc.lines[doc.cursor_y + 1];
        int next_len = next ? (int)strlen(next) : 0;
        if (len + next_len < MAX_LINE_LEN - 1) {
            if (next) strcat(line, next);
            free(doc.lines[doc.cursor_y + 1]);
            memmove(&doc.lines[doc.cursor_y + 1], &doc.lines[doc.cursor_y + 2],
                    (doc.num_lines - doc.cursor_y - 2) * sizeof(char *));
            doc.num_lines--;
            doc.modified = 1;
        }
    }
    draw_screen();
}

void backspace_char(void)
{
    char *line;
    int len;
    
    if (doc.rtl_mode) {
        line = doc.lines[doc.cursor_y];
        if (!line) return;
        len = strlen(line);
        
        /* Ensure hebrew_insert_pos is valid */
        if (hebrew_insert_pos > len) hebrew_insert_pos = len;
        
        if (len > 0 && doc.cursor_x > 0) {
            if (doc.hebrew_mode && hebrew_insert_pos < len) {
                /* Hebrew mode: delete Hebrew char at hebrew_insert_pos */
                memmove(line + hebrew_insert_pos, line + hebrew_insert_pos + 1, len - hebrew_insert_pos);
            } else if (hebrew_insert_pos > 0) {
                /* Delete LTR char from end, adjust hebrew_insert_pos */
                line[len - 1] = '\0';
                if (hebrew_insert_pos >= len) hebrew_insert_pos = len - 1;
            } else {
                /* Delete from start */
                memmove(line, line + 1, len);
            }
            doc.cursor_x--;
            doc.modified = 1;
        } else if (doc.cursor_y > 0 && len == 0) {
            /* Join with previous line */
            free(doc.lines[doc.cursor_y]);
            memmove(&doc.lines[doc.cursor_y], &doc.lines[doc.cursor_y + 1],
                    (doc.num_lines - doc.cursor_y - 1) * sizeof(char *));
            doc.num_lines--;
            doc.cursor_y--;
            doc.cursor_x = strlen(doc.lines[doc.cursor_y]);
            hebrew_insert_pos = 0;
            doc.modified = 1;
        }
    } else {
        /* LTR: normal backspace */
        if (doc.cursor_x > 0) {
            doc.cursor_x--;
            delete_char();
        } else if (doc.cursor_y > 0) {
            doc.cursor_y--;
            doc.cursor_x = strlen(doc.lines[doc.cursor_y]);
            delete_char();
        }
    }
}

void insert_line(void)
{
    char *line, *new_line;
    int len, i;
    if (doc.num_lines >= MAX_LINES) return;
    line = doc.lines[doc.cursor_y];
    len = line ? (int)strlen(line) : 0;
    new_line = (char *)malloc(MAX_LINE_LEN);
    if (!new_line) return;
    
    if (doc.rtl_mode) {
        /* RTL: new line is empty, current line keeps text */
        new_line[0] = '\0';
    } else {
        /* LTR: split at cursor position */
        if (line && doc.cursor_x < len) {
            strcpy(new_line, line + doc.cursor_x);
            line[doc.cursor_x] = '\0';
        } else {
            new_line[0] = '\0';
        }
    }
    
    for (i = doc.num_lines; i > doc.cursor_y + 1; i--)
        doc.lines[i] = doc.lines[i - 1];
    doc.lines[doc.cursor_y + 1] = new_line;
    doc.num_lines++;
    doc.cursor_y++;
    doc.cursor_x = 0;
    hebrew_insert_pos = 0;  /* Reset for new line */
    doc.modified = 1;
}

void delete_line(void)
{
    int i;
    if (doc.num_lines <= 1) {
        doc.lines[0][0] = '\0';
        doc.cursor_x = 0;
        return;
    }
    free(doc.lines[doc.cursor_y]);
    for (i = doc.cursor_y; i < doc.num_lines - 1; i++)
        doc.lines[i] = doc.lines[i + 1];
    doc.num_lines--;
    if (doc.cursor_y >= doc.num_lines)
        doc.cursor_y = doc.num_lines - 1;
    if (doc.cursor_x > (int)strlen(doc.lines[doc.cursor_y]))
        doc.cursor_x = strlen(doc.lines[doc.cursor_y]);
    doc.modified = 1;
}

void move_cursor(int dx, int dy)
{
    char *line;
    int len, old_y;
    
    old_y = doc.cursor_y;
    doc.cursor_y += dy;
    if (doc.cursor_y < 0) doc.cursor_y = 0;
    if (doc.cursor_y >= doc.num_lines) doc.cursor_y = doc.num_lines - 1;
    
    /* Reset hebrew_insert_pos when changing lines */
    if (doc.cursor_y != old_y) hebrew_insert_pos = 0;
    
    /* In RTL mode, reverse horizontal movement for visual consistency */
    if (doc.rtl_mode) dx = -dx;
    
    doc.cursor_x += dx;
    line = doc.lines[doc.cursor_y];
    len = line ? (int)strlen(line) : 0;
    
    /* Clamp cursor_x to valid range */
    if (doc.cursor_x < 0) {
        if (doc.cursor_y > 0) {
            doc.cursor_y--;
            doc.cursor_x = strlen(doc.lines[doc.cursor_y]);
            hebrew_insert_pos = 0;
        } else {
            doc.cursor_x = 0;
        }
    }
    if (doc.cursor_x > len) {
        if (dx != 0 && doc.cursor_y < doc.num_lines - 1) {
            /* Horizontal movement wraps to next line */
            doc.cursor_y++;
            line = doc.lines[doc.cursor_y];
            if (doc.rtl_mode) {
                doc.cursor_x = line ? strlen(line) : 0;
            } else {
                doc.cursor_x = 0;
            }
            hebrew_insert_pos = 0;
        } else {
            /* Vertical movement or at last line: clamp to line length */
            doc.cursor_x = len;
        }
    }
    if (doc.block_active) {
        doc.block_end_x = doc.cursor_x;
        doc.block_end_y = doc.cursor_y;
    }
    update_cursor();
}

void home_key(void) { 
    if (doc.rtl_mode) {
        /* RTL: Home goes to right edge (end of line in storage) */
        doc.cursor_x = strlen(doc.lines[doc.cursor_y]);
    } else {
        doc.cursor_x = 0;
    }
    
    update_cursor(); 
}

void end_key(void) { 
    if (doc.rtl_mode) {
        /* RTL: End goes to left edge (start of line in storage) */
        doc.cursor_x = 0;
    } else {
        doc.cursor_x = strlen(doc.lines[doc.cursor_y]);
    }
    
    update_cursor(); 
}

void page_up(void)
{
    int len;
    doc.cursor_y -= EDIT_HEIGHT;
    if (doc.cursor_y < 0) doc.cursor_y = 0;
    doc.scroll_y -= EDIT_HEIGHT;
    if (doc.scroll_y < 0) doc.scroll_y = 0;
    hebrew_insert_pos = 0;
    /* Clamp cursor_x to new line length */
    len = strlen(doc.lines[doc.cursor_y]);
    if (doc.cursor_x > len) doc.cursor_x = len;
    draw_screen();
}

void page_down(void)
{
    int len;
    doc.cursor_y += EDIT_HEIGHT;
    if (doc.cursor_y >= doc.num_lines) doc.cursor_y = doc.num_lines - 1;
    doc.scroll_y += EDIT_HEIGHT;
    if (doc.scroll_y > doc.num_lines - EDIT_HEIGHT) {
        doc.scroll_y = doc.num_lines - EDIT_HEIGHT;
        if (doc.scroll_y < 0) doc.scroll_y = 0;
    }
    hebrew_insert_pos = 0;
    /* Clamp cursor_x to new line length */
    len = strlen(doc.lines[doc.cursor_y]);
    if (doc.cursor_x > len) doc.cursor_x = len;
    draw_screen();
}

void ctrl_home(void)
{
    doc.cursor_y = doc.scroll_x = doc.scroll_y = 0;
    hebrew_insert_pos = 0;
    /* In RTL mode, cursor goes to end of first line; in LTR, to start */
    if (doc.rtl_mode) {
        doc.cursor_x = strlen(doc.lines[0]);
    } else {
        doc.cursor_x = 0;
    }
    draw_screen();
}

void ctrl_end(void)
{
    doc.cursor_y = doc.num_lines - 1;
    doc.cursor_x = strlen(doc.lines[doc.cursor_y]);
    hebrew_insert_pos = 0;
    draw_screen();
}

void toggle_insert(void)
{
    doc.insert_mode = !doc.insert_mode;
    show_cursor(doc.insert_mode);
    draw_status_bar();
}

void toggle_hebrew(void)
{
    doc.hebrew_mode = !doc.hebrew_mode;
    draw_menu_bar();
    draw_status_bar();
}

void toggle_embedded_ltr(void)
{
    if (doc.hebrew_mode) {
        doc.embedded_ltr = !doc.embedded_ltr;
        draw_menu_bar();
        draw_status_bar();
    }
}

void toggle_rtl(void) { 
    doc.rtl_mode = !doc.rtl_mode;
    doc.scroll_x = 0;
    
    draw_screen(); 
}
void toggle_wrap(void) { doc.word_wrap = !doc.word_wrap; }

void word_count(void)
{
    int i, j, words, chars, in_word;
    char msg[128];
    char *line;
    
    words = 0;
    chars = 0;
    in_word = 0;
    
    for (i = 0; i < doc.num_lines; i++) {
        line = doc.lines[i];
        if (!line) continue;
        for (j = 0; line[j]; j++) {
            chars++;
            if (line[j] == ' ' || line[j] == '\t') {
                in_word = 0;
            } else if (!in_word) {
                in_word = 1;
                words++;
            }
        }
        in_word = 0;
    }
    
    sprintf(msg, "Lines: %d  Words: %d  Chars: %d", doc.num_lines, words, chars);
    show_dialog("Word Count", msg);
}

void goto_line(void)
{
    char buf[16];
    int line_num;
    
    buf[0] = '\0';
    if (input_dialog("Go To Line", "Line number:", buf, sizeof(buf))) {
        line_num = atoi(buf);
        if (line_num < 1) line_num = 1;
        if (line_num > doc.num_lines) line_num = doc.num_lines;
        doc.cursor_y = line_num - 1;
        /* Go to start of line (visually appropriate for each mode) */
        if (doc.rtl_mode) {
            doc.cursor_x = strlen(doc.lines[doc.cursor_y]);  /* Visual left = start for RTL */
        } else {
            doc.cursor_x = 0;  /* Visual left = start for LTR */
        }
        doc.scroll_y = doc.cursor_y - EDIT_HEIGHT / 2;
        if (doc.scroll_y < 0) doc.scroll_y = 0;
        hebrew_insert_pos = 0;
        draw_screen();
    }
}

void insert_date_time(void)
{
    time_t now;
    struct tm *t;
    char buf[32];
    int i;
    
    now = time(NULL);
    t = localtime(&now);
    sprintf(buf, "%02d/%02d/%04d %02d:%02d",
            t->tm_mday, t->tm_mon + 1, t->tm_year + 1900,
            t->tm_hour, t->tm_min);
    
    for (i = 0; buf[i]; i++) {
        insert_char(buf[i]);
    }
    draw_screen();
}

void show_dialog(const char *title, const char *msg)
{
    int w, h, x1, y1, x2, y2, msg_len, title_len;
    msg_len = strlen(msg);
    title_len = strlen(title);
    w = msg_len + 6;
    if (title_len + 4 > w) w = title_len + 4;
    if (w < 20) w = 20;
    if (w > 70) w = 70;
    h = 5;
    x1 = (SCREEN_WIDTH - w) / 2;
    y1 = (SCREEN_HEIGHT - h) / 2;
    x2 = x1 + w - 1;
    y2 = y1 + h - 1;
    draw_box(x1, y1, x2, y2, CLR_DIALOG, title);
    write_string(x1 + 3, y1 + 2, msg, CLR_DIALOG);
    write_string(x1 + w/2 - 2, y1 + 4, " OK ", CLR_DIALOG_BTN);
    set_cursor_pos(x1 + w/2, y1 + 4);
    hide_cursor();
    /* Flush keyboard buffer */
    while (kbhit()) getch();
    getch();
    draw_screen();
}

int confirm_dialog(const char *title, const char *msg)
{
    int w, h, x1, y1, x2, y2, key, result = -1, msg_len, title_len, selected = 0;
    msg_len = strlen(msg);
    title_len = strlen(title);
    w = msg_len + 6;
    if (title_len + 4 > w) w = title_len + 4;
    if (w < 30) w = 30;
    if (w > 70) w = 70;
    h = 6;
    x1 = (SCREEN_WIDTH - w) / 2;
    y1 = (SCREEN_HEIGHT - h) / 2;
    x2 = x1 + w - 1;
    y2 = y1 + h - 1;
    
    /* Flush keyboard buffer */
    while (kbhit()) getch();
    
    while (result == -1) {
        draw_box(x1, y1, x2, y2, CLR_DIALOG, title);
        write_string(x1 + 3, y1 + 2, msg, CLR_DIALOG);
        /* Draw buttons with selection highlight */
        write_string(x1 + w/2 - 8, y1 + 4, selected == 0 ? "[Yes]" : " Yes ", 
                     selected == 0 ? CLR_DIALOG_BTN : CLR_DIALOG);
        write_string(x1 + w/2 + 3, y1 + 4, selected == 1 ? "[No]" : " No ", 
                     selected == 1 ? CLR_DIALOG_BTN : CLR_DIALOG);
        hide_cursor();
        
        key = getch();
        if (key == 0 || key == 0xE0) {
            /* Extended key */
            key = getch();
            if (key == KEY_LEFT || key == KEY_RIGHT) {
                selected = 1 - selected;  /* Toggle between 0 and 1 */
            }
        } else {
            key = toupper(key);
            if (key == 'Y') { result = 1; }
            else if (key == 'N') { result = 0; }
            else if (key == KEY_ENTER) { result = (selected == 0) ? 1 : 0; }
            else if (key == KEY_ESC) { result = 0; }
            else if (key == KEY_TAB || key == ' ') { selected = 1 - selected; }
        }
    }
    draw_screen();
    return result;
}

int input_dialog(const char *title, const char *prompt, char *buffer, int maxlen)
{
    int w = 60, h = 6, x1, y1, x2, y2, key, pos, len, field_x, field_w, ext_key;
    x1 = (SCREEN_WIDTH - w) / 2;
    y1 = (SCREEN_HEIGHT - h) / 2;
    x2 = x1 + w - 1;
    y2 = y1 + h - 1;
    draw_box(x1, y1, x2, y2, CLR_DIALOG, title);
    write_string(x1 + 2, y1 + 2, prompt, CLR_DIALOG);
    field_x = x1 + 2;
    field_w = w - 4;
    fill_rect(field_x, y1 + 3, field_x + field_w - 1, y1 + 3, ' ', CLR_MENU);
    write_string(field_x, y1 + 3, buffer, CLR_MENU);
    pos = strlen(buffer);
    show_cursor(1);
    set_cursor_pos(field_x + pos, y1 + 3);
    while (1) {
        key = getch();
        len = strlen(buffer);
        if (key == KEY_ENTER) { draw_screen(); return 1; }
        if (key == KEY_ESC) { draw_screen(); return 0; }
        if (key == KEY_BACKSPACE) {
            if (pos > 0) {
                memmove(buffer + pos - 1, buffer + pos, len - pos + 1);
                pos--;
            }
        } else if (key == 0 || key == 0xE0) {
            ext_key = getch();
            if (ext_key == KEY_LEFT && pos > 0) pos--;
            if (ext_key == KEY_RIGHT && pos < len) pos++;
            if (ext_key == KEY_HOME) pos = 0;
            if (ext_key == KEY_END) pos = len;
            if (ext_key == KEY_DELETE && pos < len)
                memmove(buffer + pos, buffer + pos + 1, len - pos);
        } else if (key >= 32 && key < 256 && len < maxlen - 1) {
            memmove(buffer + pos + 1, buffer + pos, len - pos + 1);
            buffer[pos] = (char)key;
            pos++;
        }
        fill_rect(field_x, y1 + 3, field_x + field_w - 1, y1 + 3, ' ', CLR_MENU);
        write_string(field_x, y1 + 3, buffer, CLR_MENU);
        set_cursor_pos(field_x + pos, y1 + 3);
    }
}

/* File browser dialog */
#define MAX_DIR_ENTRIES 200
#define FILE_LIST_HEIGHT 12

int file_dialog(const char *title, char *filename, int maxlen, int save_mode)
{
    struct find_t finfo;
    char *entries[MAX_DIR_ENTRIES];
    int is_dir[MAX_DIR_ENTRIES];
    int entry_count = 0;
    int sel = 0, top = 0, key, ext_key, i;
    char cwd[256], pattern[64];
    int x1 = 5, y1 = 3, w = 70, h = 18;
    int list_x, list_y, list_w, list_h;
    int name_x, name_y, name_w;
    int filter_idx = 0;
    const char *filters[] = { "*.TXT", "*.DOC", "*.HEB", "*.*" };
    int num_filters = 4;
    int done = 0, result = 0;
    int in_name_field = save_mode ? 1 : 0;
    int name_pos;
    char name_buf[256];
    
    /* Get current directory */
    getcwd(cwd, sizeof(cwd));
    strcpy(pattern, filters[filter_idx]);
    strcpy(name_buf, filename);
    name_pos = strlen(name_buf);
    
    /* Calculate positions */
    list_x = x1 + 2;
    list_y = y1 + 3;
    list_w = w - 4;
    list_h = FILE_LIST_HEIGHT;
    name_x = x1 + 12;
    name_y = y1 + h - 3;
    name_w = w - 16;
    
    while (!done) {
        /* Read directory */
        entry_count = 0;
        
        /* First add parent directory */
        entries[entry_count] = (char *)malloc(16);
        strcpy(entries[entry_count], "..");
        is_dir[entry_count] = 1;
        entry_count++;
        
        /* Find directories */
        if (_dos_findfirst("*.*", _A_SUBDIR, &finfo) == 0) {
            do {
                if ((finfo.attrib & _A_SUBDIR) && finfo.name[0] != '.') {
                    if (entry_count < MAX_DIR_ENTRIES) {
                        entries[entry_count] = (char *)malloc(16);
                        strncpy(entries[entry_count], finfo.name, 12);
                        entries[entry_count][12] = '\0';
                        is_dir[entry_count] = 1;
                        entry_count++;
                    }
                }
            } while (_dos_findnext(&finfo) == 0);
        }
        
        /* Find files matching pattern */
        if (_dos_findfirst(pattern, _A_NORMAL, &finfo) == 0) {
            do {
                if (!(finfo.attrib & _A_SUBDIR)) {
                    if (entry_count < MAX_DIR_ENTRIES) {
                        entries[entry_count] = (char *)malloc(16);
                        strncpy(entries[entry_count], finfo.name, 12);
                        entries[entry_count][12] = '\0';
                        is_dir[entry_count] = 0;
                        entry_count++;
                    }
                }
            } while (_dos_findnext(&finfo) == 0);
        }
        
        /* Ensure selection is valid */
        if (sel >= entry_count) sel = entry_count - 1;
        if (sel < 0) sel = 0;
        
        /* Draw dialog */
        draw_box(x1, y1, x1 + w - 1, y1 + h - 1, CLR_DIALOG, title);
        
        /* Show current directory */
        write_string(x1 + 2, y1 + 1, "Directory: ", CLR_DIALOG);
        fill_rect(x1 + 13, y1 + 1, x1 + w - 3, y1 + 1, ' ', CLR_DIALOG);
        write_string(x1 + 13, y1 + 1, cwd, CLR_DIALOG);
        
        /* Draw file list box */
        draw_box(list_x - 1, list_y - 1, list_x + list_w, list_y + list_h, CLR_MENU, NULL);
        
        /* Draw file list */
        for (i = 0; i < list_h; i++) {
            int idx = top + i;
            fill_rect(list_x, list_y + i, list_x + list_w - 1, list_y + i, ' ', 
                     (idx == sel && !in_name_field) ? CLR_MENU_SEL : CLR_MENU);
            if (idx < entry_count) {
                char display[20];
                if (is_dir[idx]) {
                    sprintf(display, "[%s]", entries[idx]);
                } else {
                    strcpy(display, entries[idx]);
                }
                write_string(list_x + 1, list_y + i, display, 
                           (idx == sel && !in_name_field) ? CLR_MENU_SEL : CLR_MENU);
            }
        }
        
        /* Draw scrollbar indicator if needed */
        if (entry_count > list_h) {
            int sb_pos = (sel * (list_h - 1)) / (entry_count - 1);
            for (i = 0; i < list_h; i++) {
                write_char(list_x + list_w - 1, list_y + i, (i == sb_pos) ? 0xDB : 0xB0, CLR_MENU);
            }
        }
        
        /* Draw filename field */
        write_string(x1 + 2, name_y, "Filename:", CLR_DIALOG);
        fill_rect(name_x, name_y, name_x + name_w - 1, name_y, ' ', in_name_field ? CLR_MENU_SEL : CLR_MENU);
        write_string(name_x, name_y, name_buf, in_name_field ? CLR_MENU_SEL : CLR_MENU);
        
        /* Draw filter */
        write_string(x1 + 2, name_y + 1, "Filter:", CLR_DIALOG);
        write_string(x1 + 10, name_y + 1, pattern, CLR_DIALOG);
        write_string(x1 + 20, name_y + 1, "(Tab to change)", CLR_DIALOG);
        
        /* Draw buttons */
        write_string(x1 + w - 22, name_y + 1, save_mode ? "[ Save ]" : "[ Open ]", CLR_DIALOG_BTN);
        write_string(x1 + w - 12, name_y + 1, "[ Cancel ]", CLR_DIALOG_BTN);
        
        /* Position cursor */
        if (in_name_field) {
            show_cursor(1);
            set_cursor_pos(name_x + name_pos, name_y);
        } else {
            hide_cursor();
        }
        
        /* Handle input */
        key = getch();
        
        if (key == KEY_ESC) {
            done = 1;
            result = 0;
        } else if (key == KEY_ENTER) {
            if (in_name_field) {
                /* Accept filename */
                if (name_buf[0] != '\0') {
                    strncpy(filename, name_buf, maxlen - 1);
                    filename[maxlen - 1] = '\0';
                    done = 1;
                    result = 1;
                }
            } else if (sel < entry_count) {
                if (is_dir[sel]) {
                    /* Change directory */
                    chdir(entries[sel]);
                    getcwd(cwd, sizeof(cwd));
                    sel = 0;
                    top = 0;
                } else {
                    /* Select file */
                    strcpy(name_buf, entries[sel]);
                    name_pos = strlen(name_buf);
                    if (!save_mode) {
                        strncpy(filename, name_buf, maxlen - 1);
                        filename[maxlen - 1] = '\0';
                        done = 1;
                        result = 1;
                    }
                }
            }
        } else if (key == KEY_TAB) {
            if (in_name_field) {
                /* Switch to file list or change filter */
                filter_idx = (filter_idx + 1) % num_filters;
                strcpy(pattern, filters[filter_idx]);
                sel = 0;
                top = 0;
            } else {
                /* Switch to name field */
                in_name_field = 1;
            }
        } else if (key == KEY_BACKSPACE) {
            if (in_name_field && name_pos > 0) {
                memmove(name_buf + name_pos - 1, name_buf + name_pos, strlen(name_buf) - name_pos + 1);
                name_pos--;
            }
        } else if (key == 0 || key == 0xE0) {
            ext_key = getch();
            if (!in_name_field) {
                if (ext_key == KEY_UP && sel > 0) {
                    sel--;
                    if (sel < top) top = sel;
                }
                if (ext_key == KEY_DOWN && sel < entry_count - 1) {
                    sel++;
                    if (sel >= top + list_h) top = sel - list_h + 1;
                }
                if (ext_key == KEY_PGUP) {
                    sel -= list_h;
                    if (sel < 0) sel = 0;
                    top = sel;
                }
                if (ext_key == KEY_PGDN) {
                    sel += list_h;
                    if (sel >= entry_count) sel = entry_count - 1;
                    if (sel >= top + list_h) top = sel - list_h + 1;
                }
                if (ext_key == KEY_HOME) { sel = 0; top = 0; }
                if (ext_key == KEY_END) { 
                    sel = entry_count - 1; 
                    top = sel - list_h + 1;
                    if (top < 0) top = 0;
                }
            } else {
                if (ext_key == KEY_LEFT && name_pos > 0) name_pos--;
                if (ext_key == KEY_RIGHT && name_pos < (int)strlen(name_buf)) name_pos++;
                if (ext_key == KEY_HOME) name_pos = 0;
                if (ext_key == KEY_END) name_pos = strlen(name_buf);
                if (ext_key == KEY_UP || ext_key == KEY_DOWN) {
                    /* Switch back to file list */
                    in_name_field = 0;
                }
            }
        } else if (key >= 32 && key < 256) {
            if (in_name_field && (int)strlen(name_buf) < maxlen - 1) {
                memmove(name_buf + name_pos + 1, name_buf + name_pos, strlen(name_buf) - name_pos + 1);
                name_buf[name_pos] = (char)key;
                name_pos++;
            } else if (!in_name_field) {
                /* Quick jump to matching file */
                char ch = toupper(key);
                for (i = sel + 1; i < entry_count; i++) {
                    if (toupper(entries[i][0]) == ch) {
                        sel = i;
                        if (sel >= top + list_h) top = sel - list_h + 1;
                        break;
                    }
                }
                if (i >= entry_count) {
                    for (i = 0; i < sel; i++) {
                        if (toupper(entries[i][0]) == ch) {
                            sel = i;
                            if (sel < top) top = sel;
                            break;
                        }
                    }
                }
            }
        }
        
        /* Free entries for re-read if directory changed */
        for (i = 0; i < entry_count; i++) {
            free(entries[i]);
        }
    }
    
    draw_screen();
    return result;
}

void show_menu(int menu_id)
{
    switch (menu_id) {
        case 0: show_file_menu(); break;
        case 1: show_edit_menu(); break;
        case 2: show_search_menu(); break;
        case 3: show_block_menu(); break;
        case 4: show_options_menu(); break;
        case 5: show_help_menu(); break;
    }
}

void show_file_menu(void)
{
    int x1 = 0, y1 = 1, w = 20, h = 10;
    int sel = 0, key, i;
    char fn[256];
    const char *items[7];
    items[0] = "New          Ctrl+N";
    items[1] = "Open              F3";
    items[2] = "Save              F2";
    items[3] = "Save As...";
    items[4] = "Print         Ctrl+P";
    items[5] = "--------------------";
    items[6] = "Exit          Alt+X";
    while (1) {
        draw_box(x1, y1, x1 + w, y1 + h, CLR_MENU, NULL);
        for (i = 0; i < 7; i++)
            write_string(x1 + 1, y1 + 1 + i, items[i], (i == sel && items[i][0] != '-') ? CLR_MENU_SEL : CLR_MENU);
        hide_cursor();
        key = getch();
        if (key == 0 || key == 0xE0) {
            key = getch();
            if (key == KEY_UP) { do { sel--; if (sel < 0) sel = 6; } while (items[sel][0] == '-'); }
            if (key == KEY_DOWN) { do { sel++; if (sel > 6) sel = 0; } while (items[sel][0] == '-'); }
            if (key == KEY_LEFT) { draw_screen(); show_help_menu(); return; }
            if (key == KEY_RIGHT) { draw_screen(); show_edit_menu(); return; }
        } else if (key == KEY_ESC) {
            break;
        } else if (key == KEY_ENTER) {
            draw_screen();
            switch (sel) {
                case 0: new_document(); break;
                case 1: 
                    fn[0] = '\0'; 
                    if (file_dialog("Open File", fn, sizeof(fn), 0)) {
                        load_file(fn); 
                    }
                    draw_screen(); 
                    break;
                case 2: save_file(doc.filename); break;
                case 3: save_file_as(); break;
                case 4: print_document(); break;
                case 6: running = 0; break;
            }
            return;
        }
    }
    draw_screen();
}

void show_edit_menu(void)
{
    int x1 = 6, y1 = 1, w = 22, h = 10;
    int sel = 0, key, i;
    const char *items[8];
    items[0] = "Undo          Ctrl+Z";
    items[1] = "Redo          Ctrl+Y";
    items[2] = "----------------------";
    items[3] = "Cut           Ctrl+X";
    items[4] = "Copy          Ctrl+C";
    items[5] = "Paste         Ctrl+V";
    items[6] = "Delete Line   Ctrl+Y";
    items[7] = "Select All    Ctrl+A";
    while (1) {
        draw_box(x1, y1, x1 + w, y1 + h, CLR_MENU, NULL);
        for (i = 0; i < 8; i++)
            write_string(x1 + 1, y1 + 1 + i, items[i], (i == sel && items[i][0] != '-') ? CLR_MENU_SEL : CLR_MENU);
        hide_cursor();
        key = getch();
        if (key == 0 || key == 0xE0) {
            key = getch();
            if (key == KEY_UP) { do { sel--; if (sel < 0) sel = 7; } while (items[sel][0] == '-'); }
            if (key == KEY_DOWN) { do { sel++; if (sel > 7) sel = 0; } while (items[sel][0] == '-'); }
            if (key == KEY_LEFT) { draw_screen(); show_file_menu(); return; }
            if (key == KEY_RIGHT) { draw_screen(); show_search_menu(); return; }
        } else if (key == KEY_ESC) {
            break;
        } else if (key == KEY_ENTER) {
            draw_screen();
            switch (sel) {
                case 0: undo_action(); break;
                case 1: redo_action(); break;
                case 3: cut_block(); break;
                case 4: copy_block(); break;
                case 5: paste_block(); break;
                case 6: delete_line(); break;
                case 7:
                    doc.block_active = 1;
                    doc.block_start_x = 0;
                    doc.block_start_y = 0;
                    doc.block_end_y = doc.num_lines - 1;
                    doc.block_end_x = strlen(doc.lines[doc.num_lines - 1]);
                    break;
            }
            draw_screen();
            return;
        }
    }
    draw_screen();
}

void show_search_menu(void)
{
    int x1 = 12, y1 = 1, w = 24, h = 8;
    int sel = 0, key, i, line;
    char buf[16];
    const char *items[6];
    items[0] = "Find...             F7";
    items[1] = "Find Next      Ctrl+L";
    items[2] = "Find Previous";
    items[3] = "Replace...          F8";
    items[4] = "Replace All";
    items[5] = "Go to Line...  Ctrl+G";
    while (1) {
        draw_box(x1, y1, x1 + w, y1 + h, CLR_MENU, NULL);
        for (i = 0; i < 6; i++)
            write_string(x1 + 1, y1 + 1 + i, items[i], (i == sel) ? CLR_MENU_SEL : CLR_MENU);
        hide_cursor();
        key = getch();
        if (key == 0 || key == 0xE0) {
            key = getch();
            if (key == KEY_UP) { sel--; if (sel < 0) sel = 5; }
            if (key == KEY_DOWN) { sel++; if (sel > 5) sel = 0; }
            if (key == KEY_LEFT) { draw_screen(); show_edit_menu(); return; }
            if (key == KEY_RIGHT) { draw_screen(); show_block_menu(); return; }
        } else if (key == KEY_ESC) {
            break;
        } else if (key == KEY_ENTER) {
            draw_screen();
            switch (sel) {
                case 0: do_search(); break;
                case 1: find_next(); break;
                case 2: find_prev(); break;
                case 3: do_replace(); break;
                case 4: do_replace_all(); break;
                case 5:
                    buf[0] = '\0';
                    if (input_dialog("Go to Line", "Line number:", buf, sizeof(buf))) {
                        line = atoi(buf);
                        if (line > 0 && line <= doc.num_lines) {
                            doc.cursor_y = line - 1;
                            doc.cursor_x = 0;
                        }
                    }
                    draw_screen();
                    break;
            }
            return;
        }
    }
    draw_screen();
}

