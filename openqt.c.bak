    draw_screen();
}

void show_help_menu(void)
{
    int x1 = 44, y1 = 1, w = 20, h = 7;
    int sel = 0, key, i;
    const char *items[4];
    items[0] = "Help Index      F1";
    items[1] = "Keyboard Help";
    items[2] = "------------------";
    items[3] = "About OpenQT...";
    while (1) {
        draw_box(x1, y1, x1 + w, y1 + h, CLR_MENU, NULL);
        for (i = 0; i < 4; i++)
            write_string(x1 + 1, y1 + 1 + i, items[i], (i == sel && items[i][0] != '-') ? CLR_MENU_SEL : CLR_MENU);
        hide_cursor();
        key = getch();
        if (key == 0 || key == 0xE0) {
            key = getch();
            if (key == KEY_UP) { do { sel--; if (sel < 0) sel = 3; } while (items[sel][0] == '-'); }
            if (key == KEY_DOWN) { do { sel++; if (sel > 3) sel = 0; } while (items[sel][0] == '-'); }
            if (key == KEY_LEFT) { draw_screen(); show_tools_menu(); return; }
            if (key == KEY_RIGHT) { draw_screen(); show_file_menu(); return; }
        } else if (key == KEY_ESC) {
            break;
        } else if (key == KEY_ENTER) {
            draw_screen();
            switch (sel) {
                case 0: case 1: show_help(); break;
                case 3: show_about(); break;
            }
            return;
        }
    }
    draw_screen();
}

void do_search(void)
{
    if (input_dialog("Find", "Search for:", search_text, sizeof(search_text)))
        find_next();
}

void find_next(void)
{
    int i, j, len, search_len;
    char *line;
    if (!search_text[0]) { do_search(); return; }
    search_len = strlen(search_text);
    for (i = doc.cursor_y; i < doc.num_lines; i++) {
        line = doc.lines[i];
        if (!line) continue;
        len = strlen(line);
        j = (i == doc.cursor_y) ? doc.cursor_x + 1 : 0;
        for (; j <= len - search_len; j++) {
            if ((search_case ? strncmp(line + j, search_text, search_len) : strnicmp(line + j, search_text, search_len)) == 0) {
                doc.cursor_y = i;
                doc.cursor_x = j;
                doc.block_active = 1;
                doc.block_start_x = j;
                doc.block_start_y = i;
                doc.block_end_x = j + search_len;
                doc.block_end_y = i;
                draw_screen();
                return;
            }
        }
    }
    show_dialog("Search", "Text not found");
}

void find_prev(void)
{
    int i, j, len, search_len;
    char *line;
    if (!search_text[0]) { do_search(); return; }
    search_len = strlen(search_text);
    for (i = doc.cursor_y; i >= 0; i--) {
        line = doc.lines[i];
        if (!line) continue;
        len = strlen(line);
        j = (i == doc.cursor_y) ? doc.cursor_x - 1 : len - search_len;
        if (j > len - search_len) j = len - search_len;
        for (; j >= 0; j--) {
            if ((search_case ? strncmp(line + j, search_text, search_len) : strnicmp(line + j, search_text, search_len)) == 0) {
                doc.cursor_y = i;
                doc.cursor_x = j;
                doc.block_active = 1;
                doc.block_start_x = j;
                doc.block_start_y = i;
                doc.block_end_x = j + search_len;
                doc.block_end_y = i;
                draw_screen();
                return;
            }
        }
    }
    show_dialog("Search", "Text not found");
}

void do_replace(void)
{
    char *line;
    int search_len, replace_len, line_len;
    if (!input_dialog("Replace", "Search for:", search_text, sizeof(search_text))) return;
    if (!input_dialog("Replace", "Replace with:", replace_text, sizeof(replace_text))) return;
    find_next();
    if (doc.block_active && confirm_dialog("Replace", "Replace this occurrence?")) {
        line = doc.lines[doc.cursor_y];
        search_len = strlen(search_text);
        replace_len = strlen(replace_text);
        line_len = strlen(line);
        memmove(line + doc.cursor_x + replace_len, line + doc.cursor_x + search_len, line_len - doc.cursor_x - search_len + 1);
        memcpy(line + doc.cursor_x, replace_text, replace_len);
        doc.modified = 1;
        doc.block_active = 0;
        draw_screen();
    }
}

void do_replace_all(void)
{
    int count = 0, i, j, len, search_len, replace_len;
    char *line, *found, msg[64];
    if (!input_dialog("Replace All", "Search for:", search_text, sizeof(search_text))) return;
    if (!input_dialog("Replace All", "Replace with:", replace_text, sizeof(replace_text))) return;
    search_len = strlen(search_text);
    replace_len = strlen(replace_text);
    for (i = 0; i < doc.num_lines; i++) {
        line = doc.lines[i];
        if (!line) continue;
        j = 0;
        while (1) {
            len = strlen(line);
            found = search_case ? strstr(line + j, search_text) : stristr(line + j, search_text);
            if (!found) break;
            j = (int)(found - line);
            memmove(line + j + replace_len, line + j + search_len, len - j - search_len + 1);
            memcpy(line + j, replace_text, replace_len);
            j += replace_len;
            count++;
        }
    }
    if (count > 0) doc.modified = 1;
    sprintf(msg, "%d replacement(s) made", count);
    show_dialog("Replace All", msg);
    draw_screen();
}

void start_block(void)
{
    doc.block_active = 1;
    doc.block_start_x = doc.block_end_x = doc.cursor_x;
    doc.block_start_y = doc.block_end_y = doc.cursor_y;
}

void end_block(void)
{
    if (doc.block_active) {
        doc.block_end_x = doc.cursor_x;
        doc.block_end_y = doc.cursor_y;
        draw_screen();
    }
}

void unselect_block(void) { doc.block_active = 0; }

void copy_block(void)
{
    int i, by1, by2, bx1, bx2, start_col, end_col, len;
    if (!doc.block_active) { start_block(); return; }
    if (doc.clipboard) {
        for (i = 0; i < doc.clipboard_lines; i++)
            if (doc.clipboard[i]) free(doc.clipboard[i]);
        free(doc.clipboard);
    }
    by1 = doc.block_start_y < doc.block_end_y ? doc.block_start_y : doc.block_end_y;
    by2 = doc.block_start_y > doc.block_end_y ? doc.block_start_y : doc.block_end_y;
    if (doc.block_start_y == doc.block_end_y) {
        bx1 = doc.block_start_x < doc.block_end_x ? doc.block_start_x : doc.block_end_x;
        bx2 = doc.block_start_x > doc.block_end_x ? doc.block_start_x : doc.block_end_x;
    } else if (doc.block_start_y < doc.block_end_y) {
        bx1 = doc.block_start_x;
        bx2 = doc.block_end_x;
    } else {
        bx1 = doc.block_end_x;
        bx2 = doc.block_start_x;
    }
    doc.clipboard_lines = by2 - by1 + 1;
    doc.clipboard = (char **)malloc(doc.clipboard_lines * sizeof(char *));
    for (i = 0; i < doc.clipboard_lines; i++) {
        int line_idx = by1 + i;
        char *src = doc.lines[line_idx];
        int src_len = src ? (int)strlen(src) : 0;
        if (doc.clipboard_lines == 1) { start_col = bx1; end_col = bx2; }
        else if (i == 0) { start_col = bx1; end_col = src_len; }
        else if (i == doc.clipboard_lines - 1) { start_col = 0; end_col = bx2; }
        else { start_col = 0; end_col = src_len; }
        if (start_col > src_len) start_col = src_len;
        if (end_col > src_len) end_col = src_len;
        len = end_col - start_col;
        doc.clipboard[i] = (char *)malloc(len + 1);
        if (len > 0 && src) strncpy(doc.clipboard[i], src + start_col, len);
        doc.clipboard[i][len] = '\0';
    }
}

void cut_block(void) { copy_block(); delete_block(); }

void paste_block(void)
{
    int i;
    char *line;
    int cur_len, paste_len;
    char *rest = NULL;
    if (!doc.clipboard || doc.clipboard_lines == 0) return;
    if (doc.clipboard_lines == 1) {
        line = doc.lines[doc.cursor_y];
        cur_len = strlen(line);
        paste_len = strlen(doc.clipboard[0]);
        if (cur_len + paste_len < MAX_LINE_LEN - 1) {
            memmove(line + doc.cursor_x + paste_len, line + doc.cursor_x, cur_len - doc.cursor_x + 1);
            memcpy(line + doc.cursor_x, doc.clipboard[0], paste_len);
            doc.cursor_x += paste_len;
            doc.modified = 1;
        }
    } else {
        line = doc.lines[doc.cursor_y];
        cur_len = strlen(line);
        if (doc.cursor_x < cur_len) {
            rest = (char *)malloc(cur_len - doc.cursor_x + 1);
            strcpy(rest, line + doc.cursor_x);
            line[doc.cursor_x] = '\0';
        }
        strcat(line, doc.clipboard[0]);
        for (i = 1; i < doc.clipboard_lines; i++) {
            if (doc.num_lines >= MAX_LINES) break;
            memmove(&doc.lines[doc.cursor_y + i + 1], &doc.lines[doc.cursor_y + i], (doc.num_lines - doc.cursor_y - i) * sizeof(char *));
            doc.lines[doc.cursor_y + i] = (char *)malloc(MAX_LINE_LEN);
            strcpy(doc.lines[doc.cursor_y + i], doc.clipboard[i]);
            doc.num_lines++;
        }
        if (rest) {
            strcat(doc.lines[doc.cursor_y + doc.clipboard_lines - 1], rest);
            free(rest);
        }
        doc.cursor_y += doc.clipboard_lines - 1;
        doc.cursor_x = strlen(doc.clipboard[doc.clipboard_lines - 1]);
        doc.modified = 1;
    }
}

void delete_block(void)
{
    int i, by1, by2, bx1, bx2;
    char *first_line, *last_line;
    if (!doc.block_active) return;
    by1 = doc.block_start_y < doc.block_end_y ? doc.block_start_y : doc.block_end_y;
    by2 = doc.block_start_y > doc.block_end_y ? doc.block_start_y : doc.block_end_y;
    if (doc.block_start_y == doc.block_end_y) {
        bx1 = doc.block_start_x < doc.block_end_x ? doc.block_start_x : doc.block_end_x;
        bx2 = doc.block_start_x > doc.block_end_x ? doc.block_start_x : doc.block_end_x;
    } else if (doc.block_start_y < doc.block_end_y) {
        bx1 = doc.block_start_x;
        bx2 = doc.block_end_x;
    } else {
        bx1 = doc.block_end_x;
        bx2 = doc.block_start_x;
    }
    if (by1 == by2) {
        char *ln = doc.lines[by1];
        int l = strlen(ln);
        memmove(ln + bx1, ln + bx2, l - bx2 + 1);
    } else {
        first_line = doc.lines[by1];
        last_line = doc.lines[by2];
        first_line[bx1] = '\0';
        strcat(first_line, last_line + bx2);
        for (i = by1 + 1; i <= by2; i++) free(doc.lines[i]);
        memmove(&doc.lines[by1 + 1], &doc.lines[by2 + 1], (doc.num_lines - by2 - 1) * sizeof(char *));
        doc.num_lines -= (by2 - by1);
    }
    doc.cursor_y = by1;
    doc.cursor_x = bx1;
    doc.block_active = 0;
    doc.modified = 1;
    draw_screen();
}

void show_help(void)
{
    int x1 = 5, y1 = 3, x2 = 74, y2 = 21;
    draw_box(x1, y1, x2, y2, CLR_DIALOG, " OpenQT Help ");
    write_string(x1 + 2, y1 + 2, "KEYBOARD SHORTCUTS:", CLR_DIALOG);
    write_string(x1 + 2, y1 + 4, "F1  - Help                  F2  - Save file", CLR_DIALOG);
    write_string(x1 + 2, y1 + 5, "F3  - Open file             F4  - Toggle Hebrew/English kbd", CLR_DIALOG);
    write_string(x1 + 2, y1 + 6, "F5  - Toggle RTL/LTR        F6  - Copy block", CLR_DIALOG);
    write_string(x1 + 2, y1 + 7, "F7  - Find                  F8  - Replace", CLR_DIALOG);
    write_string(x1 + 2, y1 + 8, "F9  - Paste                 F10 - Menu", CLR_DIALOG);
    write_string(x1 + 2, y1 + 10, "Ctrl+Home - Start of doc    Ctrl+End - End of doc", CLR_DIALOG);
    write_string(x1 + 2, y1 + 11, "Home      - Start of line   End      - End of line", CLR_DIALOG);
    write_string(x1 + 2, y1 + 13, "RTL MODE (F5):", CLR_DIALOG);
    write_string(x1 + 2, y1 + 14, "  HEB keyboard (F4): Hebrew typed right-to-left", CLR_DIALOG);
    write_string(x1 + 2, y1 + 15, "  ENG keyboard (F4): English/numbers left-to-right", CLR_DIALOG);
    write_string(x1 + 2, y1 + 17, "Alt+X     - Exit OpenQT", CLR_DIALOG);
    write_string(x1 + 25, y2 - 1, " Press any key to continue ", CLR_DIALOG_BTN);
    hide_cursor();
    getch();
    draw_screen();
}

void show_about(void)
{
    int x1 = 15, y1 = 7, x2 = 64, y2 = 17;
    draw_box(x1, y1, x2, y2, CLR_DIALOG, " About OpenQT ");
    write_string(x1 + 10, y1 + 2, "OpenQT - Hebrew Word Processor", CLR_DIALOG);
    write_string(x1 + 15, y1 + 3, "Version " VERSION, CLR_DIALOG);
    write_string(x1 + 8, y1 + 5, "A QText 5.5 Compatible Clone", CLR_DIALOG);
    write_string(x1 + 12, y1 + 7, "Open Source / Public Domain", CLR_DIALOG);
    write_string(x1 + 17, y2 - 1, " OK ", CLR_DIALOG_BTN);
    hide_cursor();
    getch();
    draw_screen();
}

void print_document(void)
{
    FILE *prn;
    int i;
    if (!confirm_dialog("Print", "Send document to printer?")) return;
    prn = fopen("PRN", "w");
    if (!prn) { show_dialog("Error", "Cannot access printer!"); return; }
    for (i = 0; i < doc.num_lines; i++) {
        if (doc.lines[i]) fputs(doc.lines[i], prn);
        fputs("\r\n", prn);
    }
    fputc(12, prn);
    fclose(prn);
    show_dialog("Print", "Document sent to printer");
}

void undo_action(void) { show_dialog("Undo", "Undo not yet implemented"); }
void redo_action(void) { show_dialog("Redo", "Redo not yet implemented"); }

void process_key(int key, int extended)
{
    unsigned char ch;
    char fn[256];
    int spaces;
    
    if (extended) {
        switch (key & 0xFF) {
            case KEY_UP: move_cursor(0, -1); break;
            case KEY_DOWN: move_cursor(0, 1); break;
            case KEY_LEFT: move_cursor(-1, 0); break;
            case KEY_RIGHT: move_cursor(1, 0); break;
            case KEY_HOME: home_key(); break;
            case KEY_END: end_key(); break;
            case KEY_PGUP: page_up(); break;
            case KEY_PGDN: page_down(); break;
            case KEY_INSERT: toggle_insert(); break;
            case KEY_DELETE: delete_char(); break;
            case KEY_CTRL_HOME: ctrl_home(); break;
            case KEY_CTRL_END: ctrl_end(); break;
            case KEY_CTRL_LEFT: move_cursor(-5, 0); break;
            case KEY_CTRL_RIGHT: move_cursor(5, 0); break;
            case KEY_F1: show_help(); break;
            case KEY_F2: save_file(doc.filename); draw_screen(); break;
            case KEY_F3:
                fn[0] = '\0';
                if (file_dialog("Open File", fn, sizeof(fn), 0)) {
                    load_file(fn);
                    draw_screen();
                }
                break;
            case KEY_F4: toggle_hebrew(); draw_screen(); break;
            case KEY_F5: toggle_rtl(); draw_screen(); break;
            case KEY_F6: copy_block(); break;
            case KEY_F7: do_search(); break;
            case KEY_F8: do_replace(); break;
            case KEY_F9: paste_block(); draw_screen(); break;
            case KEY_F10: show_menu(0); break;
            case KEY_ALT_F: show_file_menu(); break;
            case KEY_ALT_E: show_edit_menu(); break;
            case KEY_ALT_S: show_search_menu(); break;
            case KEY_ALT_B: show_block_menu(); break;
            case KEY_ALT_O: show_options_menu(); break;
            case KEY_ALT_T: show_tools_menu(); break;
            case KEY_ALT_H: show_help_menu(); break;
            case KEY_ALT_X: running = 0; break;
        }
    } else {
        switch (key) {
            case KEY_ESC:
                unselect_block();
                draw_screen();
                break;
            case KEY_ENTER:
                insert_line();
                draw_screen();
                break;
            case KEY_BACKSPACE:
                backspace_char();
                draw_screen();
                break;
            case KEY_TAB:
                spaces = TAB_SIZE - (doc.cursor_x % TAB_SIZE);
                while (spaces--) insert_char(' ');
                draw_screen();
                break;
            case KEY_CTRL_G:
                goto_line();
                break;
            case KEY_CTRL_N:
                new_document();
                break;
            case KEY_CTRL_S:
                save_file(doc.filename);
                draw_status_bar();
                break;
            default:
                if (key >= 32 && key < 256) {
                    ch = (unsigned char)key;
                    /* Only translate to Hebrew if hebrew_mode is ON */
                    /* Never translate numbers - they stay as-is */
                    if (doc.hebrew_mode && ch >= 32 && ch < 128 && !(ch >= '0' && ch <= '9')) {
                        unsigned char heb = translate_hebrew(ch);
                        if (heb) ch = heb;
                    }
                    insert_char(ch);
                    draw_screen();
                }
                break;
        }
    }
}

void init_editor(void)
{
    /* Don't reset video mode - HEBVGA.COM already loaded the Hebrew font */
    /* Just clear the screen by filling with spaces */
    int i;
    for (i = 0; i < SCREEN_WIDTH * SCREEN_HEIGHT * 2; i += 2) {
        video_mem[i] = ' ';
        video_mem[i + 1] = CLR_NORMAL;
    }
    init_hebrew_mapping();
    init_document();
}

void cleanup_editor(void)
{
    /* Don't reset video mode - preserve Hebrew font for DOS */
    /* Just clear screen and restore cursor */
    int i;
    for (i = 0; i < SCREEN_WIDTH * SCREEN_HEIGHT * 2; i += 2) {
        video_mem[i] = ' ';
        video_mem[i + 1] = 0x07;  /* Normal DOS colors */
    }
    free_document();
    show_cursor(1);
    set_cursor_pos(0, 0);
}

int main(int argc, char *argv[])
{
    int key;
    init_editor();
    if (argc > 1) load_file(argv[1]);
    draw_screen();
    while (running) {
        key = get_key();
        if (key & 0x100) process_key(key, 1);
        else process_key(key, 0);
        draw_status_bar();
        update_cursor();
    }
    if (doc.modified) {
        if (confirm_dialog("Exit", "Save changes before exit?"))
            save_file(doc.filename);
    }
    cleanup_editor();
    return 0;
}
