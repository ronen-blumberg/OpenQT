            if (key == KEY_LEFT) { draw_screen(); show_options_menu(); return; }
            if (key == KEY_RIGHT) { draw_screen(); show_help_menu(); return; }
        } else if (key == KEY_ESC) {
            break;
        } else if (key == KEY_ENTER) {
            draw_screen();
            switch (sel) {
