        hide_cursor();
        key = getch();
        if (key == 0 || key == 0xE0) {
            key = getch();
            if (key == KEY_UP) { sel--; if (sel < 0) sel = 6; }
            if (key == KEY_DOWN) { sel++; if (sel > 6) sel = 0; }
            if (key == KEY_LEFT) { draw_screen(); show_search_menu(); return; }
            if (key == KEY_RIGHT) { draw_screen(); show_options_menu(); return; }
        } else if (key == KEY_ESC) {
            break;
        } else if (key == KEY_ENTER) {
            draw_screen();
            switch (sel) {
                case 0: start_block(); break;
                case 1: end_block(); break;
                case 2: copy_block(); break;
                case 3: cut_block(); paste_block(); break;
                case 4: delete_block(); break;
                case 5: unselect_block(); break;
            }
            draw_screen();
            return;
        }
