    draw_screen();
}

void show_options_menu(void)
{
    int x1 = 29, y1 = 1, w = 24, h = 10;
    int sel = 0, key, i;
    char items[8][30];
    while (1) {
        sprintf(items[0], "[%c] Hebrew Mode    F4", doc.hebrew_mode ? 'X' : ' ');
        sprintf(items[1], "[%c] RTL Mode       F5", doc.rtl_mode ? 'X' : ' ');
        sprintf(items[2], "[%c] Word Wrap", doc.word_wrap ? 'X' : ' ');
        sprintf(items[3], "[%c] Show Ruler", doc.show_ruler ? 'X' : ' ');
        sprintf(items[4], "[%c] Insert Mode   Ins", doc.insert_mode ? 'X' : ' ');
        strcpy(items[5], "------------------------");
        strcpy(items[6], "Set Colors...");
        draw_box(x1, y1, x1 + w, y1 + h, CLR_MENU, NULL);
        for (i = 0; i < 7; i++)
            write_string(x1 + 1, y1 + 1 + i, items[i], (i == sel && items[i][0] != '-') ? CLR_MENU_SEL : CLR_MENU);
        hide_cursor();
        key = getch();
        if (key == 0 || key == 0xE0) {
            key = getch();
            if (key == KEY_UP) { do { sel--; if (sel < 0) sel = 6; } while (items[sel][0] == '-'); }
            if (key == KEY_DOWN) { do { sel++; if (sel > 6) sel = 0; } while (items[sel][0] == '-'); }
            if (key == KEY_LEFT) { draw_screen(); show_block_menu(); return; }
            if (key == KEY_RIGHT) { draw_screen(); show_tools_menu(); return; }
        } else if (key == KEY_ESC) {
            break;
        } else if (key == KEY_ENTER || key == ' ') {
            switch (sel) {
                case 0: toggle_hebrew(); break;
                case 1: toggle_rtl(); break;
                case 2: toggle_wrap(); break;
                case 3: doc.show_ruler = !doc.show_ruler; break;
                case 4: toggle_insert(); break;
            }
            if (sel >= 5) { draw_screen(); return; }
        }
    }
    draw_screen();
}

